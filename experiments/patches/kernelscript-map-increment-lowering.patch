+     map_def.map_type = IRMapArray && is_integer_ir_type map_def.map_value_type
+
+and emit_array_map_atomic_add ctx map_name key_expr delta_expr pos =
+  let map_def = Hashtbl.find ctx.maps map_name in
+  let key_val = lower_expression ctx key_expr in
+  let delta_val = lower_expression ctx delta_expr in
+  let map_val =
