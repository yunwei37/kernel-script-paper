+           && Map_assignment.is_constant_expression delta_expr ->
+      Some delta_expr
+  | Ast.BinaryOp (delta_expr,
+                  Ast.Add,
+                  { Ast.expr_desc = Ast.ArrayAccess ({ Ast.expr_desc = Ast.Identifier read_map; _ }, read_key); _ })
+      when read_map = map_name
+           && same_source_expr read_key key_expr
+           && Map_assignment.is_constant_expression delta_expr ->
