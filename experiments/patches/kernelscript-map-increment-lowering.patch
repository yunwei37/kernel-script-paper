+  | _ -> false
+
+and same_source_expr left right =
+  Ast.string_of_expr left = Ast.string_of_expr right
+
+and find_map_self_add_delta map_name key_expr value_expr =
+  match value_expr.Ast.expr_desc with
+  | Ast.BinaryOp ({ Ast.expr_desc = Ast.ArrayAccess ({ Ast.expr_desc = Ast.Identifier read_map; _ }, read_key); _ },
+                  Ast.Add,
+                  delta_expr)
+      when read_map = map_name
